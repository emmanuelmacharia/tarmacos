# Port the Hono server listens on.
PORT=8080

# Shared secret the main app must send as `Authorization: Bearer <secret>`.
# Generate a strong value (e.g. `openssl rand -hex 32`) and set the SAME value
# as RENDERER_SHARED_SECRET in the main app's environment.
RENDERER_SHARED_SECRET=change-me

# Base URL of the Gotenberg sidecar (Chromium + LibreOffice rendering engine).
# Local docker-compose: http://gotenberg:3000
# Railway: the private/internal URL of the Gotenberg service.
GOTENBERG_URL=http://localhost:3000

# Optional: total wall-clock budget for a single Gotenberg call, in ms.
GOTENBERG_TIMEOUT_MS=30000
