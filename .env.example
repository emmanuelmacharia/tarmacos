PUBLIC_CLERK_PUBLISHABLE_KEY=sha
CLERK_SECRET_KEY=ska
PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=http://foo
PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=http://foo

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev # team: foo, project: bar

PUBLIC_CONVEX_URL=https://foo

PUBLIC_CONVEX_SITE_URL=https://foo

OPEN_ROUTER_API_KEY=sk-or-v1-foo

PUBLIC_POSTHOG_PROJECT_TOKEN=phc

# Convex deployment env var (set via `npx convex env set`, not loaded from this file).
# Comma-separated Clerk user ids allowed to manage templates (internal admin API).
ADMIN_USER_IDS=user_abc,user_def

# Renderer service (services/renderer) — used by src/lib/server/render client.
# RENDERER_SHARED_SECRET must match the value set on the renderer service.
RENDERER_URL=http://localhost:8080
RENDERER_SHARED_SECRET=change-me